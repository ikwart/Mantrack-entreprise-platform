# Copy this file to .env before running docker-compose up
# ----------------------------------------------------------------------------

# Warehouse database (schema.sql + seed data loads here)
DW_DB_USER=mantrac_admin
DW_DB_PASSWORD=change_me_dw
DW_DB_NAME=mantrac_dw

# Airflow metadata database (kept separate from the warehouse)
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=change_me_airflow
AIRFLOW_DB_NAME=airflow_meta

# Airflow web UI login (http://localhost:8080)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me_admin

# Note: Java + PySpark + the Spark/Kafka/Postgres Python packages are now
# baked into the custom Airflow image (see airflow/Dockerfile), so there's
# no need for an additional-requirements env var anymore. Run
# `docker-compose build` once after cloning, or whenever airflow/requirements.txt
# changes.
